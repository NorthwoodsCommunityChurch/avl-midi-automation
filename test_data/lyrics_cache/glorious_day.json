    {
      "uuid": "BD3B2F1E-1AB5-4FA0-B93A-E29F141E47ED",
      "name": "Bridge",
      "slides": [
        {
          "text": "I needed rescue my sin was heavy\nBut chains break at the weight of Your glory",
          "label": "",
          "enabled": true
        },
        {
          "text": "I needed shelter I was an orphan\nNow You call me a citizen of Heaven",
