      "slides": [
        {
          "text": "At the cross at the cross\nI surrender my life",
          "label": "",
          "enabled": true
        },
        {
          "text": "I'm in awe of You \nI'm in awe of You",
          "label": "",
          "enabled": true
        },
        {
          "text": "Where Your love ran red \nand my sin washed white",
          "label": "",
          "enabled": true
        },
        {
          "text": "I owe all to You \nI owe all to You",
          "label": "",
          "enabled": true
