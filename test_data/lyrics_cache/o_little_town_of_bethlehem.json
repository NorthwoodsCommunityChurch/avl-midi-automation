      "name": "Verse 1",
      "slides": [
        {
          "text": "O little town of Bethlehem",
          "label": "",
          "enabled": true
        },
        {
          "text": "How still we see thee lie",
          "label": "",
          "enabled": true
        },
        {
          "text": "Above thy deep and dreamless sleep",
          "label": "",
          "enabled": true
        },
        {
          "text": "The silent stars go by",
          "label": "",
          "enabled": true
        },
        {
          "text": "Yet in thy dark streets shineth",
          "label": "",
          "enabled": true
        },
        {
          "text": "The everlasting light",
          "label": "",
          "enabled": true
        },
        {
          "text": "The hopes and fears of all the years",
          "label": "",
          "enabled": true
        },
        {
          "text": "Are met in thee tonight",
          "label": "",
          "enabled": true
        }
      ]
